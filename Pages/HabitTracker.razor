@page "/habits"
@inject HabitService HabitSvc
@inject IJSRuntime JS

<PageTitle>Habits</PageTitle>

<div class="flex flex-col h-dvh bg-gray-50 dark:bg-gray-950 overflow-hidden">

    <HabitHeader Habits="@_habits"
                 SelectedHabitId="@_selectedId"
                 SelectedHabitIdChanged="OnHabitSelected"
                 IsDarkMode="@_dark"
                 OnAddHabitClicked="() => _showAddHabit = true"
                 OnToggleDarkMode="ToggleDark" />

    @if (_selected is not null)
    {
        <!-- Tabs -->
        <div class="flex bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 shrink-0">
            <button class="flex-1 py-2.5 text-sm font-semibold border-b-2 bg-transparent transition-colors
                           @(!_stats ? "text-green-600 border-green-600"
                                     : "text-gray-500 dark:text-gray-400 border-transparent")"
                    @onclick="() => _stats = false">Grid</button>
            <button class="flex-1 py-2.5 text-sm font-semibold border-b-2 bg-transparent transition-colors
                           @(_stats  ? "text-green-600 border-green-600"
                                     : "text-gray-500 dark:text-gray-400 border-transparent")"
                    @onclick="() => _stats = true">Statistics</button>
        </div>

        @if (!_stats)
        {
            <HabitGridView EntriesByDate="@_entries"
                           Today="@_today"
                           IsDarkMode="@_dark"
                           OnDayClicked="OpenEntryForDay"
                           OnAddEntryClicked="OpenNewEntry" />
        }
        else
        {
            <HabitStatsView EntriesByDate="@_entries"
                            SelectedHabit="@_selected"
                            Today="@_today"
                            OnDeleteHabit="DeleteHabit" />
        }
    }
    else if (_habits.Count == 0)
    {
        <div class="flex-1 flex flex-col items-center justify-center gap-4 p-8 text-center animate-empty-in">
            <div class="text-6xl">📋</div>
            <p class="text-sm text-gray-500 dark:text-gray-400 max-w-[260px] leading-relaxed">
                Track your daily habits and visualise your progress.
            </p>
            <button class="px-6 py-3 rounded-xl bg-green-600 hover:bg-green-700 active:scale-95 text-white text-sm font-semibold transition-all"
                    @onclick="() => _showAddHabit = true">Create your first habit</button>
        </div>
    }

</div>

<AddHabitModal Show="@_showAddHabit"
               ShowChanged="v => _showAddHabit = v"
               OnSave="AddHabit" />

<AddEntryModal Show="@_showAddEntry"
               ShowChanged="v => _showAddEntry = v"
               InitialEntry="@_draftEntry"
               EditingEntry="@_editingEntry"
               ExistingDates="@_entries.Keys"
               OnSave="SaveEntry"
               OnDelete="DeleteEntry" />

@code {
    // ── State ──────────────────────────────────────────────────────────────────
    private List<Habit>                    _habits   = [];
    private string                         _selectedId = "";
    private Habit?                         _selected => _habits.FirstOrDefault(h => h.Id == _selectedId);
    private Dictionary<string, HabitEntry> _entries  = [];
    private readonly DateOnly              _today    = DateOnly.FromDateTime(DateTime.Today);

    private bool _stats, _showAddHabit, _showAddEntry, _dark, _shouldScroll;

    // Entry form state (owned here so modals get fresh snapshots)
    private HabitEntry? _draftEntry;
    private HabitEntry? _editingEntry;

    // ── Lifecycle ──────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _habits = [.. (await HabitSvc.GetHabitsAsync()).OrderBy(h => h.CreatedAt)];
        if (_habits.Count > 0) { _selectedId = _habits[0].Id; await LoadEntries(); _shouldScroll = true; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dark = await JS.InvokeAsync<bool>("darkMode.isDark");
            StateHasChanged();
        }
        if (_shouldScroll)
        {
            _shouldScroll = false;
            await JS.InvokeVoidAsync("scrollToBottom", "ht-grid-scroll");
        }
    }

    // ── Navigation ─────────────────────────────────────────────────────────────
    private async Task OnHabitSelected(string id)
    {
        _selectedId = id;
        _stats = false;
        await LoadEntries();
        _shouldScroll = true;
    }

    private async Task LoadEntries()
    {
        if (_selected is null) return;
        var list = await HabitSvc.GetEntriesAsync(_selected.Id);
        _entries = list.ToDictionary(e => e.Date, e => e);
    }

    private async Task ToggleDark()
        => _dark = await JS.InvokeAsync<bool>("darkMode.toggle");

    // ── Habit CRUD ─────────────────────────────────────────────────────────────
    private async Task AddHabit(Habit habit)
    {
        await HabitSvc.SaveHabitAsync(habit);
        _habits.Add(habit);
        _selectedId = habit.Id;
        await LoadEntries();
        _stats = false;
    }

    private async Task DeleteHabit()
    {
        if (_selected is null) return;
        foreach (var e in await HabitSvc.GetEntriesAsync(_selected.Id))
            await HabitSvc.DeleteEntryAsync(e.Id);
        await HabitSvc.DeleteHabitAsync(_selected.Id);
        _habits.Remove(_selected);
        _selectedId = _habits.Count > 0 ? _habits[0].Id : "";
        await LoadEntries();
        _stats = false;
    }

    // ── Entry CRUD ─────────────────────────────────────────────────────────────
    private void OpenNewEntry()
    {
        _editingEntry = null;
        _draftEntry   = new HabitEntry { HabitId = _selected!.Id, Date = _today.ToString("yyyy-MM-dd"), Completeness = 100 };
        _showAddEntry = true;
    }

    private void OpenEntryForDay(DateOnly date)
    {
        if (date > _today) return;
        var key = date.ToString("yyyy-MM-dd");
        _entries.TryGetValue(key, out var existing);
        _editingEntry = existing;
        _draftEntry   = existing is not null
            ? new HabitEntry { Id = existing.Id, HabitId = existing.HabitId, Date = existing.Date, Completeness = existing.Completeness, Notes = existing.Notes }
            : new HabitEntry { HabitId = _selected!.Id, Date = key, Completeness = 100 };
        _showAddEntry = true;
    }

    private async Task SaveEntry(HabitEntry entry)
    {
        entry.HabitId = _selected!.Id;
        await HabitSvc.SaveEntryAsync(entry);
        _entries[entry.Date] = entry;
    }

    private async Task DeleteEntry(HabitEntry entry)
    {
        await HabitSvc.DeleteEntryAsync(entry.Id);
        _entries.Remove(entry.Date);
    }
}
