@page "/habits"
@using TaskManager.Models
@using TaskManager.Services
@inject HabitService HabitSvc

<PageTitle>Habit Tracker</PageTitle>

<div class="ht-root">

    <!-- ── Top bar: habit selector + add habit ── -->
    <div class="ht-topbar">
        @if (habits.Count == 0)
        {
            <span class="ht-no-habits">No habits yet</span>
        }
        else
        {
            <select class="ht-select" @bind="selectedHabitId" @bind:after="OnHabitChanged">
                @foreach (var h in habits)
                {
                    <option value="@h.Id">@h.Name</option>
                }
            </select>
        }
        <button class="ht-btn ht-btn-outline" @onclick="OpenAddHabit">+ Habit</button>
    </div>

    @if (selectedHabit is not null)
    {
        <!-- ── View tabs ── -->
        <div class="ht-tabs">
            <button class="ht-tab @(showStats ? "" : "active")" @onclick="() => showStats = false">Grid</button>
            <button class="ht-tab @(showStats ? "active" : "")" @onclick="() => showStats = true">Statistics</button>
        </div>

        @if (!showStats)
        {
            <!-- ════ GRID VIEW ════ -->
            <div class="ht-grid-scroll">
                <!-- Sticky weekday header -->
                <div class="ht-weekday-row">
                    @foreach (var d in new[] { "Mo", "Tu", "We", "Th", "Fr", "Sa", "Su" })
                    {
                        <div class="ht-weekday-label">@d</div>
                    }
                </div>

                @foreach (var month in GetMonthsToDisplay())
                {
                    var daysInMonth = DateTime.DaysInMonth(month.Year, month.Month);
                    var firstDay = new DateOnly(month.Year, month.Month, 1);
                    var offset = ((int)firstDay.DayOfWeek + 6) % 7; // Monday = 0

                    <div class="ht-month-section">
                        <div class="ht-month-label">@firstDay.ToString("MMMM yyyy")</div>
                        <div class="ht-day-grid">
                            @for (int i = 0; i < offset; i++)
                            {
                                <div class="ht-day-cell ht-day-empty"></div>
                            }
                            @for (int d = 1; d <= daysInMonth; d++)
                            {
                                var date = new DateOnly(month.Year, month.Month, d);
                                var isFuture = date > today;
                                var key = date.ToString("yyyy-MM-dd");
                                var hasEntry = entriesByDate.TryGetValue(key, out var entry);
                                var completeness = hasEntry ? entry!.Completeness : -1;
                                var dayNum = d; // capture for lambda
                                <div class="ht-day-cell @(isFuture ? "ht-day-future" : "")"
                                     style="@(isFuture ? "" : $"background-color:{GetColor(completeness)};")"
                                     title="@GetTooltip(date, completeness, isFuture)"
                                     @onclick="() => OnDayClick(date, hasEntry ? entry : null)">
                                    <span class="ht-day-num">@dayNum</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- ── Bottom: add entry ── -->
            <div class="ht-bottombar">
                <button class="ht-btn ht-btn-primary" @onclick="OpenAddEntry">+ Add Entry</button>
            </div>
        }
        else
        {
            <!-- ════ STATISTICS VIEW ════ -->
            <div class="ht-stats">
                @{
                    var allEntries = entriesByDate.Values.ToList();
                    var entryCount = allEntries.Count;
                    var avgCompletion = entryCount > 0 ? (int)allEntries.Average(e => e.Completeness) : 0;
                    var (currentStreak, longestStreak) = ComputeStreaks();
                    var perfect = allEntries.Count(e => e.Completeness == 100);
                    var habitStart = DateOnly.Parse(selectedHabit.CreatedAt);
                    var totalDays = today.DayNumber - habitStart.DayNumber + 1;
                    var completionRate = totalDays > 0 ? (int)(entryCount * 100.0 / totalDays) : 0;
                }

                <div class="ht-stat-card">
                    <div class="ht-stat-value">@entryCount</div>
                    <div class="ht-stat-label">Total entries</div>
                </div>
                <div class="ht-stat-card">
                    <div class="ht-stat-value">@avgCompletion<span class="ht-stat-unit">%</span></div>
                    <div class="ht-stat-label">Avg completeness</div>
                </div>
                <div class="ht-stat-card">
                    <div class="ht-stat-value">@completionRate<span class="ht-stat-unit">%</span></div>
                    <div class="ht-stat-label">Days tracked</div>
                </div>
                <div class="ht-stat-card">
                    <div class="ht-stat-value">@currentStreak</div>
                    <div class="ht-stat-label">Current streak</div>
                </div>
                <div class="ht-stat-card">
                    <div class="ht-stat-value">@longestStreak</div>
                    <div class="ht-stat-label">Longest streak</div>
                </div>
                <div class="ht-stat-card">
                    <div class="ht-stat-value">@perfect</div>
                    <div class="ht-stat-label">Perfect days (100%)</div>
                </div>

                <!-- Mini heatmap strip: last 30 days -->
                <div class="ht-stat-section-title">Last 30 days</div>
                <div class="ht-mini-strip">
                    @for (int i = 29; i >= 0; i--)
                    {
                        var date = today.AddDays(-i);
                        var key = date.ToString("yyyy-MM-dd");
                        var completeness = entriesByDate.TryGetValue(key, out var e2) ? e2.Completeness : -1;
                        <div class="ht-strip-cell"
                             style="background-color:@GetColor(completeness);"
                             title="@date.ToString("MMM d"): @(completeness >= 0 ? completeness + "%" : "No entry")">
                        </div>
                    }
                </div>

                <!-- Delete habit -->
                <div class="ht-stat-danger">
                    <button class="ht-btn ht-btn-danger" @onclick="DeleteHabit">Delete habit</button>
                </div>
            </div>
        }
    }
    else if (habits.Count == 0)
    {
        <div class="ht-empty-state">
            <div class="ht-empty-icon">📋</div>
            <p>Track your daily habits and visualise your progress.</p>
            <button class="ht-btn ht-btn-primary" @onclick="OpenAddHabit">Create your first habit</button>
        </div>
    }

</div>

<!-- ════ ADD HABIT MODAL ════ -->
@if (showAddHabit)
{
    <div class="ht-overlay" @onclick="() => showAddHabit = false">
        <div class="ht-modal" @onclick:stopPropagation>
            <h2 class="ht-modal-title">New Habit</h2>
            <label class="ht-label">Name</label>
            <input class="ht-input" placeholder="e.g. Morning run" @bind="newHabit.Name" @bind:event="oninput" maxlength="60" />
            <label class="ht-label">Description <span class="ht-optional">(optional)</span></label>
            <textarea class="ht-textarea" placeholder="What does success look like?" @bind="newHabit.Description" rows="3"></textarea>
            @if (!string.IsNullOrEmpty(formError))
            {
                <p class="ht-error">@formError</p>
            }
            <div class="ht-modal-actions">
                <button class="ht-btn ht-btn-outline" @onclick="() => showAddHabit = false">Cancel</button>
                <button class="ht-btn ht-btn-primary" @onclick="AddHabit">Save</button>
            </div>
        </div>
    </div>
}

<!-- ════ ADD / EDIT ENTRY MODAL ════ -->
@if (showAddEntry)
{
    <div class="ht-overlay" @onclick="() => showAddEntry = false">
        <div class="ht-modal" @onclick:stopPropagation>
            <h2 class="ht-modal-title">@(editingEntry is not null ? "Edit Entry" : "Add Entry")</h2>
            <label class="ht-label">Date</label>
            <input class="ht-input" type="date" @bind="entryDateString" />
            <label class="ht-label">Completeness: <strong>@newEntry.Completeness%</strong></label>
            <input class="ht-range" type="range" min="0" max="100" step="5"
                   @bind="newEntry.Completeness" @bind:event="oninput" />
            <div class="ht-range-labels">
                <span>0%</span><span>50%</span><span>100%</span>
            </div>
            <label class="ht-label">Notes <span class="ht-optional">(optional)</span></label>
            <textarea class="ht-textarea" placeholder="How did it go?" @bind="newEntry.Notes" rows="3"></textarea>
            @if (!string.IsNullOrEmpty(formError))
            {
                <p class="ht-error">@formError</p>
            }
            <div class="ht-modal-actions">
                @if (editingEntry is not null)
                {
                    <button class="ht-btn ht-btn-danger" @onclick="DeleteEntry">Delete</button>
                }
                <button class="ht-btn ht-btn-outline" @onclick="() => showAddEntry = false">Cancel</button>
                <button class="ht-btn ht-btn-primary" @onclick="SaveEntry">Save</button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ──────────────────────────────────────────
    private List<Habit> habits = [];
    private string selectedHabitId = "";
    private Habit? selectedHabit => habits.FirstOrDefault(h => h.Id == selectedHabitId);
    private Dictionary<string, HabitEntry> entriesByDate = [];
    private DateOnly today = DateOnly.FromDateTime(DateTime.Today);

    private bool showStats;
    private bool showAddHabit;
    private bool showAddEntry;
    private string formError = "";

    private Habit newHabit = new();
    private HabitEntry newEntry = new();
    private HabitEntry? editingEntry;

    // Two-way bind for date input (type="date" needs yyyy-MM-dd string)
    private string entryDateString
    {
        get => newEntry.Date;
        set => newEntry.Date = value;
    }

    // ── Lifecycle ──────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        habits = await HabitSvc.GetHabitsAsync();
        habits = [.. habits.OrderBy(h => h.CreatedAt)];
        if (habits.Count > 0)
        {
            selectedHabitId = habits[0].Id;
            await LoadEntries();
        }
    }

    private async Task OnHabitChanged()
    {
        showStats = false;
        await LoadEntries();
    }

    private async Task LoadEntries()
    {
        if (selectedHabit is null) return;
        var list = await HabitSvc.GetEntriesAsync(selectedHabit.Id);
        entriesByDate = list.ToDictionary(e => e.Date, e => e);
    }

    // ── Grid helpers ───────────────────────────────────
    private List<DateOnly> GetMonthsToDisplay()
    {
        var months = new List<DateOnly>();
        DateOnly start;
        if (selectedHabit is not null && DateOnly.TryParse(selectedHabit.CreatedAt, out var created))
            start = new DateOnly(created.Year, created.Month, 1);
        else
            start = new DateOnly(today.Year, today.Month, 1).AddMonths(-11);

        // Cap at 12 months back from today
        var cap = new DateOnly(today.Year, today.Month, 1).AddMonths(-11);
        if (start < cap) start = cap;

        for (var m = start; m <= today; m = m.AddMonths(1))
            months.Add(m);
        return months;
    }

    private static string GetColor(int completeness) => completeness switch
    {
        < 0  => "#ebedf0",  // no entry
        0    => "#ebedf0",
        <= 25 => "#9be9a8",
        <= 50 => "#40c463",
        <= 75 => "#30a14e",
        _    => "#216e39",
    };

    private static string GetTooltip(DateOnly date, int completeness, bool isFuture)
    {
        if (isFuture) return date.ToString("MMM d");
        return completeness >= 0
            ? $"{date:MMM d}: {completeness}%"
            : $"{date:MMM d}: No entry";
    }

    // ── Day click: open edit modal if entry exists, else add new ──
    private void OnDayClick(DateOnly date, HabitEntry? entry)
    {
        if (date > today) return;
        editingEntry = entry;
        newEntry = entry is not null
            ? new HabitEntry { Id = entry.Id, HabitId = entry.HabitId, Date = entry.Date, Completeness = entry.Completeness, Notes = entry.Notes }
            : new HabitEntry { HabitId = selectedHabit!.Id, Date = date.ToString("yyyy-MM-dd"), Completeness = 100 };
        formError = "";
        showAddEntry = true;
    }

    // ── Add Habit ──────────────────────────────────────
    private void OpenAddHabit()
    {
        newHabit = new Habit();
        formError = "";
        showAddHabit = true;
    }

    private async Task AddHabit()
    {
        if (string.IsNullOrWhiteSpace(newHabit.Name))
        {
            formError = "Please enter a name.";
            return;
        }
        await HabitSvc.SaveHabitAsync(newHabit);
        habits.Add(newHabit);
        selectedHabitId = newHabit.Id;
        await LoadEntries();
        showAddHabit = false;
        showStats = false;
    }

    private async Task DeleteHabit()
    {
        if (selectedHabit is null) return;
        // Delete all entries first
        var entries = await HabitSvc.GetEntriesAsync(selectedHabit.Id);
        foreach (var e in entries)
            await HabitSvc.DeleteEntryAsync(e.Id);

        await HabitSvc.DeleteHabitAsync(selectedHabit.Id);
        habits.Remove(selectedHabit);
        selectedHabitId = habits.Count > 0 ? habits[0].Id : "";
        await LoadEntries();
        showStats = false;
    }

    // ── Add / Edit Entry ───────────────────────────────
    private void OpenAddEntry()
    {
        editingEntry = null;
        newEntry = new HabitEntry
        {
            HabitId = selectedHabit!.Id,
            Date = today.ToString("yyyy-MM-dd"),
            Completeness = 100
        };
        formError = "";
        showAddEntry = true;
    }

    private async Task SaveEntry()
    {
        if (string.IsNullOrWhiteSpace(newEntry.Date))
        {
            formError = "Please select a date.";
            return;
        }
        if (editingEntry is null)
        {
            // Check for duplicate date
            if (entriesByDate.ContainsKey(newEntry.Date))
            {
                formError = "An entry for this date already exists. Tap the day cell to edit it.";
                return;
            }
        }

        newEntry.HabitId = selectedHabit!.Id;
        await HabitSvc.SaveEntryAsync(newEntry);
        entriesByDate[newEntry.Date] = newEntry;
        showAddEntry = false;
    }

    private async Task DeleteEntry()
    {
        if (editingEntry is null) return;
        await HabitSvc.DeleteEntryAsync(editingEntry.Id);
        entriesByDate.Remove(editingEntry.Date);
        showAddEntry = false;
    }

    // ── Statistics ─────────────────────────────────────
    private (int current, int longest) ComputeStreaks()
    {
        if (entriesByDate.Count == 0) return (0, 0);

        int current = 0, longest = 0, run = 0;

        // Walk backwards from today
        for (var d = today; d >= today.AddDays(-365); d = d.AddDays(-1))
        {
            if (entriesByDate.TryGetValue(d.ToString("yyyy-MM-dd"), out var e) && e.Completeness > 0)
            {
                run++;
                if (run > longest) longest = run;
                if (d > today.AddDays(-run)) current = run; // still contiguous from today
            }
            else
            {
                if (current == 0) current = run > 0 ? 0 : 0; // not contiguous from today
                run = 0;
            }
        }

        // Recalculate current streak properly
        current = 0;
        for (var d = today; ; d = d.AddDays(-1))
        {
            if (entriesByDate.TryGetValue(d.ToString("yyyy-MM-dd"), out var e) && e.Completeness > 0)
                current++;
            else
                break;
        }

        return (current, longest);
    }
}
